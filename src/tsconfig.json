{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",

    "baseUrl": ".",

      "paths": {
        "@/*": ["*"]
      },

    "types": ["vite/client"]
    ,
    "ignoreDeprecations": "6.0"
  },

  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.d.ts"
  ]
}
